# AlgoQX Studio -- Environment Configuration
# Copy this file to .env and fill in your values

# LLM Configuration
LLM_BASE_URL=https://ollama.algoqx.tech/v1
LLM_API_KEY=sk-ollama-algoqx-2024
LLM_DEFAULT_MODEL=llama3.1:8b

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/algoqx.db

# Embedding Models
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_FALLBACK_MODEL=all-MiniLM-L6-v2

# FAISS
FAISS_INDEX_PATH=./data/faiss_index

# Server
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=8501

# Security
SECRET_KEY=algoqx-studio-secret-change-in-production
